---
import { CATEGORIES } from "../lib/constants";
---

<header class="border-b border-surface-lighter bg-surface/80 backdrop-blur-sm sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="text-2xl font-bold text-text hover:text-accent transition-colors">
      AI<span class="text-accent">News</span>
    </a>
    <nav class="hidden md:flex items-center gap-6">
      {CATEGORIES.slice(0, 5).map((cat) => (
        <a
          href={`/category/${cat.slug}`}
          class="text-sm text-text-muted hover:text-accent transition-colors"
        >
          {cat.label}
        </a>
      ))}
      <a
        href="/newsletter"
        class="text-sm bg-primary hover:bg-primary-dark text-white px-4 py-2 rounded-lg transition-colors"
      >
        Subscribe
      </a>
    </nav>
  </div>
</header>
